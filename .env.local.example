# ─────────────────────────────────────────────────────────────────────────────
# MALI — environment template. Copy to .env.local and fill in.
# In Vercel: set each variable for Production + Preview + Development as needed.
# Never commit .env.local. Only this *.example file is checked in.
# ─────────────────────────────────────────────────────────────────────────────

# ── Sanity CMS ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-05-14
# Server-only token with `viewer` scope (or `editor` if you want previews).
# Used by the Studio + draft-mode reads.
SANITY_API_TOKEN=
# Shared secret for the /api/revalidate webhook. Set the same value in
# Sanity → Project → API → Webhooks → Secret.
SANITY_REVALIDATE_SECRET=

# ── Shopify Storefront ──────────────────────────────────────────────────────
# The myshopify.com host, e.g. mali-shop.myshopify.com (NOT the public domain).
SHOPIFY_STORE_DOMAIN=
# Public Storefront API token (Shopify admin → Apps → Headless / custom app).
# Required scopes: read_products, read_product_listings, write_checkouts.
SHOPIFY_STOREFRONT_API_TOKEN=
SHOPIFY_STOREFRONT_API_VERSION=2026-01

# ── Social feed ─────────────────────────────────────────────────────────────
# The Instagram feed is a Curator.io widget embedded in components/CuratorFeed.tsx
# (the published feed id is set there). No env var needed; manage the connected
# accounts and appearance from the Curator dashboard at https://curator.io.

# ── Klaviyo ─────────────────────────────────────────────────────────────────
# Private API key — server only. Scopes: lists:write, profiles:write, subscriptions:write.
KLAVIYO_PRIVATE_API_KEY=
# Numeric list ID, visible in the Klaviyo URL when viewing the target list.
KLAVIYO_LIST_ID=

# ── Contact form (SendGrid) ─────────────────────────────────────────────────
# The /api/contact route only sends mail when SENDGRID_API_KEY is set —
# otherwise it just logs and returns ok (the message goes nowhere).
SENDGRID_API_KEY=
# Inbox that contact submissions are delivered to. Defaults to
# realmalimusic@gmail.com if unset.
CONTACT_EMAIL=
# NOTE: the From address (noreply@akilahmali.com) must be a verified sender
# in SendGrid, or sends fail silently.

# ── Upstash Redis (rate limiting) ───────────────────────────────────────────
# Provisioned via Vercel Marketplace → Upstash → Connect. That integration
# auto-injects KV_REST_API_URL / KV_REST_API_TOKEN — the code reads those as a
# fallback, so you don't need to set the two below on Vercel. Use the
# read-WRITE token (KV_REST_API_TOKEN), not KV_REST_API_READ_ONLY_TOKEN.
# The rate limiter fails OPEN if no URL+token is found. For local dev, set:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Analytics ───────────────────────────────────────────────────────────────
# Plausible — the production domain you registered in Plausible. Leave empty
# in dev/preview so the script never loads. Vercel Analytics + Speed Insights
# need no config; they auto-detect Vercel deploys.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# ── Sentry ──────────────────────────────────────────────────────────────────
# DSN appears on both client + server. Keep them separate so you can swap.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Used by withSentryConfig at build time for source-map upload.
SENTRY_ORG=
SENTRY_PROJECT=
# Sentry org auth token (Settings → Account → Auth Tokens, scope: project:releases).
SENTRY_AUTH_TOKEN=

# ── MailerLite (active email list — takes priority over Klaviyo when set) ───
# mailerlite.com → Integrations → Developer API → generate token.
MAILERLITE_API_KEY=
# Optional: numeric group id to file signups into (visible in the group URL).
MAILERLITE_GROUP_ID=

# ── Lead magnet ─────────────────────────────────────────────────────────────
# Download/gated-track URL surfaced after a successful email signup.
# TODO(akilah): point at the free demo / voice memo / lyric PDF once it exists.
NEXT_PUBLIC_LEAD_MAGNET_URL=

# ── Shop ────────────────────────────────────────────────────────────────────
# Real storefront URL (e.g. https://akilahmali.bandcamp.com). Every "shop"
# nav/footer link sitewide stays hidden until this is set.
NEXT_PUBLIC_SHOP_URL=

# ── Marketing tags (privacy-aware: nothing loads until these are set) ───────
# tagmanager.google.com → your container → GTM-XXXXXXX
NEXT_PUBLIC_GTM_ID=
# business.facebook.com → Events Manager → Data Sources → your pixel id
NEXT_PUBLIC_META_PIXEL_ID=
